# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Authentication ─────────────────────────────────
# JSON array of bcrypt-hashed PINs with admin names.
# Generate hashes: node -e "const b=require('bcryptjs');b.hash('0000',10).then(h=>console.log(h))"
# Format: [{"hash":"$2a$10$...","name":"Admin"},{"hash":"$2a$10$...","name":"Humaan"}]
ADMIN_PIN_HASHES=[{"hash":"GENERATE_WITH_BCRYPT","name":"Admin"},{"hash":"GENERATE_WITH_BCRYPT","name":"Humaan"}]

# ─── API Security ─────────────────────────────────────────
# Shared secret for internal API routes (Gemini, appliances, admin team).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=generate-a-random-secret-here
NEXT_PUBLIC_API_SECRET_KEY=same-value-as-API_SECRET_KEY

# ─── External Services ───────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_WHATSAPP_NUMBER=971501234567
NEXT_PUBLIC_FB_PIXEL_ID=your-pixel-id
